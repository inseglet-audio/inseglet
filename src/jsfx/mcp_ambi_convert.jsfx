@init
deg = 0;            // 64 slots [0..63]: ACN degree l per channel index
gval = 64;          // 64 slots [64..127]: per-channel gain for the active mode
i = 0;
loop(64,
  deg[i] = floor(sqrt(i) + 0.0001);   // epsilon guards the perfect-square floor
  i += 1;
);

@slider
mm = mode | 0;
i = 0;
loop(64,
  l = deg[i];
  b = sqrt(2*l + 1);
  gval[i] = mm == 0 ? b : (mm == 1 ? 1.0/b : 1.0);
  i += 1;
);

@sample
mm = mode | 0;
n = min(num_ch, 64);
mm < 2 ? (
  // Normalization change: identity channel map, per-degree scalar gain (any order).
  c = 0;
  loop(n, spl(c) = spl(c) * gval[c]; c += 1;);
) : mm == 2 ? (
  // ambiX (ACN/SN3D) -> FuMa, first order only: reorder W Y Z X -> W X Y Z, W *= 1/sqrt2.
  num_ch >= 4 ? (
    w = spl(0); yy = spl(1); zz = spl(2); xx = spl(3);
    spl(0) = w * 0.70710678118654752;
    spl(1) = xx;
    spl(2) = yy;
    spl(3) = zz;
  );
) : (
  // FuMa -> ambiX (ACN/SN3D), first order only: reorder W X Y Z -> W Y Z X, W *= sqrt2.
  num_ch >= 4 ? (
    w = spl(0); xx = spl(1); yy = spl(2); zz = spl(3);
    spl(0) = w * 1.41421356237309505;
    spl(1) = yy;
    spl(2) = zz;
    spl(3) = xx;
  );
);
