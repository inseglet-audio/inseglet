@init
deg = 0;             // 64 slots [0..63]: ACN degree l per channel index
sgn = 64;            // 64 slots [64..127]: per-channel sign for the active plane
i = 0;
loop(64,
  deg[i] = floor(sqrt(i) + 0.0001);
  i += 1;
);

@slider
pl = plane | 0;
i = 0;
loop(64,
  l = deg[i];
  m = i - l*l - l;
  am = abs(m);
  pl == 0 ? (
    sgn[i] = m < 0 ? -1 : 1;
  ) : pl == 1 ? (
    e = m >= 0 ? am : am + 1;
    sgn[i] = 1 - 2*(e - 2*floor(e/2));
  ) : (
    e = l + am;
    sgn[i] = 1 - 2*(e - 2*floor(e/2));
  );
  i += 1;
);

@sample
n = min(num_ch, 64);
c = 0;
loop(n, spl(c) = spl(c) * sgn[c]; c += 1;);
